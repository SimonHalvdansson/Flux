<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_preview"
    style="@style/Widget.Flux.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/current_price_header_preview"
        style="@style/Widget.Flux.AppWidget.Text.Header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="11:00-12:00:" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-1dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/current_price_value_preview"
            style="@style/Widget.Flux.AppWidget.Text.Price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:includeFontPadding="false"
            android:text="1.42" />

        <TextView
            android:id="@+id/current_price_unit_preview"
            style="@style/Widget.Flux.AppWidget.Text.Unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginLeft="5dp"
            android:includeFontPadding="false"
            android:text="kr/kWh" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            android:paddingLeft="6dp">

            <TextView
                android:id="@+id/max_price_text_preview"
                style="@style/Widget.Flux.AppWidget.Text.Extrema"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8593; 2.18 17:00-18:00" />

            <TextView
                android:id="@+id/min_price_text_preview"
                style="@style/Widget.Flux.AppWidget.Text.Extrema"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8595; 0.74 03:00-04:00" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="horizontal">

                <ImageView
                    android:background="@drawable/bar_rounded_old"
                    android:minHeight="28dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded_old"
                    android:minHeight="44dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded_old"
                    android:minHeight="31dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded_old"
                    android:minHeight="52dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded_old"
                    android:minHeight="37dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded_current"
                    android:minHeight="74dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded"
                    android:minHeight="46dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:background="@drawable/bar_rounded"
