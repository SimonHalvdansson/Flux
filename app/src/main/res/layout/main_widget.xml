                    android:minHeight="30dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_3"
                    android:background="@drawable/bar_rounded_current"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_4"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_5"
                    android:background="@drawable/bar_rounded"
