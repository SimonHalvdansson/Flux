                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_7"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_8"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_9"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_10"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_11"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_12"
                    android:background="@drawable/bar_rounded"
