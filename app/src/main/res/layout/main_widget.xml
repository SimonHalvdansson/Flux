<!-- res/layout/flux_widget.xml -->
<LinearLayout xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.Flux.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        tools:text="10:00-10:15"
        android:id="@+id/current_price_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Flux.AppWidget.Text.Header"/>


    <LinearLayout
        android:layout_marginTop="-1dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <TextView
        tools:text="1.92"
        android:id="@+id/current_price_imageview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:includeFontPadding="false"
        style="@style/Widget.Flux.AppWidget.Text.Price" />


    <TextView
        tools:text="kr/kWh"
        android:layout_gravity="bottom"
        android:id="@+id/current_price_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:includeFontPadding="false"
        style="@style/Widget.Flux.AppWidget.Text.Unit" />


    <LinearLayout
        android:paddingLeft="6dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <TextView
            tools:text="max 1.26 01:00-02:00"
            android:id="@+id/max_price_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Flux.AppWidget.Text.Extrema" />


        <TextView
            tools:text="min 0.44 13:00-14:00"
            android:id="@+id/min_price_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Flux.AppWidget.Text.Extrema" />


    </LinearLayout>

</LinearLayout>


    <FrameLayout
