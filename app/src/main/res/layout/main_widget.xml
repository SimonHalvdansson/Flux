                <ImageView
                    android:id="@+id/bar_14"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_15"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_16"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_17"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_18"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
