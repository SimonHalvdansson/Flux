                    android:id="@+id/bar_19"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_20"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_21"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_22"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />
                <ImageView
                    android:id="@+id/bar_23"
                    android:background="@drawable/bar_rounded"
                    android:minHeight="70dp"
                    style="@style/Widget.Flux.AppWidget.Bar" />

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/graph_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/api_error_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_marginBottom="2dp"
                android:src="@drawable/icon_api_error"
                android:layout_width="38dp"
                android:layout_height="38dp"/>

            <TextView
                tools:text="ENTSO-E API error"
                android:id="@+id/api_error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Flux.AppWidget.Text.ApiError" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/widget_time_container"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
