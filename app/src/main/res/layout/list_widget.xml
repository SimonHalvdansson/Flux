<LinearLayout
    android:id="@+id/widget_root_list"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    style="@style/Widget.Flux.AppWidget.Container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@null"
    >

    <LinearLayout
        android:paddingTop="16dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            tools:text="10:00-10:15"
            android:id="@+id/current_price_header_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.Flux.AppWidget.Text.ListHeader"/>

        <LinearLayout
            android:layout_marginTop="-1dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                tools:text="1.92"
                android:id="@+id/current_price_imageview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:includeFontPadding="false"
                style="@style/Widget.Flux.AppWidget.Text.Price" />

            <TextView
                tools:text="kr/kWh"
                android:layout_gravity="bottom"
                android:id="@+id/current_price_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:includeFontPadding="false"
                style="@style/Widget.Flux.AppWidget.Text.Unit" />
        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:listSelector="@android:color/transparent"
            android:dividerHeight="0dp"/>

        <LinearLayout
            android:id="@+id/api_error_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_marginBottom="2dp"
                android:src="@drawable/icon_api_error"
                android:layout_width="38dp"
                android:layout_height="38dp"/>

            <TextView
                tools:text="ENTSO-E API error"
                android:id="@+id/api_error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/Widget.Flux.AppWidget.Text.ApiError" />
        </LinearLayout>

    </FrameLayout>
</LinearLayout>

