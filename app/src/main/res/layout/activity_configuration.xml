<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <io.github.simonhalvdansson.flux.MainBackdropView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <io.github.simonhalvdansson.flux.NoiseOverlayView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <ScrollView
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/main_content_horizontal_padding"
        android:paddingTop="@dimen/config_content_top_padding"
        android:paddingEnd="@dimen/main_content_horizontal_padding"
        android:paddingBottom="@dimen/config_content_bottom_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/config_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/productsans_bold"
                android:text="@string/widget_settings_title"
                android:textColor="@color/main_price_emphasis"
                android:textSize="28sp" />

            <LinearLayout
                android:id="@+id/main_widget_settings_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="236dp"
                    android:layout_marginBottom="20dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:padding="8dp">

                    <include
                        android:id="@+id/chart_widget_preview"
                        layout="@layout/main_widget"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:elevation="18dp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/productsans_bold"
                    android:text="@string/widget_chart_mode_title"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/chart_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chart_bars_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/chart_bars" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chart_graph_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/chart_graph" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chart_lines_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/chart_lines" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:id="@+id/bar_pool_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/widget_bar_pool_title"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/bar_pool_toggle_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bar_pool_min_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_min" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bar_pool_average_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_average" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/bar_pool_max_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_max" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/list_widget_settings_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/productsans_bold"
                    android:text="@string/widget_list_increment_title"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/list_increment_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/increment_15_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/increment_15_minutes" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/increment_30_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/increment_30_minutes" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/increment_60_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/increment_1_hour" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/increment_120_button"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/increment_2_hours" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:id="@+id/list_pool_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/productsans_bold"
                        android:text="@string/widget_list_pool_title"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/list_pool_toggle_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/list_pool_min_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_min" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/list_pool_average_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_average" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/list_pool_max_button"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/productsans_bold"
                            android:text="@string/pool_max" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/done_button"
                style="@style/Widget.Material3Expressive.Button.ElevatedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="?attr/colorSecondary"
                android:fontFamily="@font/productsans_bold"
                android:text="@string/add_widget"
                android:textColor="?attr/colorOnSecondary"
                app:icon="@drawable/ic_add_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorOnSecondary" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
